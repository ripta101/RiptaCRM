datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  name         String
  email        String
  role         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
