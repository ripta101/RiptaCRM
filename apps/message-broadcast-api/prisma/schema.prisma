datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

model MessageBroadcast {
  id              String    @id @default(uuid())
  title           String
  bodyHtml        String
  priority        Int       @default(0) // 0=none, 1=LOW, 2=NORMAL, 3=HIGH — see BroadcastPriority in shared-types
  startAt         DateTime
  endAt           DateTime
  canceledAt      DateTime?
  createdByUserId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  targetProfiles MessageBroadcastTargetProfile[]
}

model MessageBroadcastTargetProfile {
  id          String           @id @default(uuid())
  broadcastId String
  broadcast   MessageBroadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  profileId   String // plain, unvalidated — mirrors ProfileUser.userId; access-management-api owns Profiles
  createdAt   DateTime         @default(now())

  @@unique([broadcastId, profileId])
}
