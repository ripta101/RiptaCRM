datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

model Profile {
  id                   String    @id @default(uuid())
  name                 String    @unique
  isProtected          Boolean   @default(false)
  dashboardType        String // "frontline" | "admin"
  canStartInteractions Boolean   @default(false)
  maxConcurrentChats   Int       @default(3)
  archivedAt           DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  navItems ProfileNavItem[]
  members  ProfileUser[]

  // Supervisor-scope grants: WebChat queues and other Profiles this Profile's members
  // (acting as supervisors) may see on the Supervisor Dashboard. Union semantics — see
  // webchat-api's routes/supervisor.ts.
  supervisedQueues ProfileSupervisedQueue[]
  supervisorOf     ProfileSupervisedProfile[] @relation("Supervisor")
  supervisedBy     ProfileSupervisedProfile[] @relation("Supervised")
}

model ProfileNavItem {
  id        String   @id @default(uuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  navItemId String // id from the fixed shared-types nav-item registry — not a DB FK
  createdAt DateTime @default(now())

  @@unique([profileId, navItemId])
}

model ProfileUser {
  id        String   @id @default(uuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  userId    String // plain, unvalidated — mirrors QueueMember.userId; auth-api owns Users
  createdAt DateTime @default(now())

  @@unique([profileId, userId])
}

model ProfileSupervisedQueue {
  id        String   @id @default(uuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  queueId   String // plain, unvalidated — webchat-api's WebChatQueue.id; mirrors ProfileUser.userId
  createdAt DateTime @default(now())

  @@unique([profileId, queueId])
}

model ProfileSupervisedProfile {
  id                  String   @id @default(uuid())
  profileId           String // the supervisor Profile
  profile             Profile  @relation("Supervisor", fields: [profileId], references: [id], onDelete: Cascade)
  supervisedProfileId String // real FK — Profiles are local to this service
  supervisedProfile   Profile  @relation("Supervised", fields: [supervisedProfileId], references: [id], onDelete: Cascade)
  createdAt           DateTime @default(now())

  @@unique([profileId, supervisedProfileId])
}

model MenuItem {
  id             String   @id @default(uuid())
  label          String
  displayType    String // "IFRAME" | "MFE"
  iframeUrl      String?
  remoteEntryUrl String?
  remoteName     String?
  exposedModule  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
