{
  "name": "@riptacrm/webchat-widget",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.config.iframe.ts",
    "build:loader": "vite build --config vite.config.loader.ts",
    "build:iframe": "vite build --config vite.config.iframe.ts",
    "build:mfe": "vite build --config vite.config.mfe.ts",
    "build": "pnpm run build:loader && pnpm run build:iframe && pnpm run build:mfe",
    "serve": "pnpm run build && serve dist -l 5179",
    "test:e2e:serve": "pnpm run build && serve dist -l 5179",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"no lint configured\""
  },
  "dependencies": {
    "@riptacrm/shared-types": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@module-federation/vite": "^1.16.16",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "serve": "^14.2.3",
    "typescript": "^5.7.0",
    "vite": "^5.4.10"
  }
}
